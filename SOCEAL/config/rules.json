{
  "rules": [
    {
      "id": "LOGIN_BRUTEFORCE",
      "name": "Brute-Force Login",
      "type": "eventlog",
      "event_id": 4625,
      "window_seconds": 60,
      "threshold": 10,
      "action": "block_ip",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "ACCOUNT_LOCKOUT",
      "name": "Account Lockout",
      "type": "eventlog",
      "event_id": 4740,
      "action": "log",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "PRIVILEGE_ESCALATION",
      "name": "Privilege Escalation Attempt",
      "type": "eventlog",
      "event_id": 4672,
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "TOKEN_IMPERSONATION",
      "name": "Token Impersonation / Pass-the-Hash",
      "type": "eventlog",
      "event_id": 4624,
      "logon_type": 3,
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "USER_ADDED_TO_ADMINS",
      "name": "User Added to Administrators Group",
      "type": "eventlog",
      "event_id": 4732,
      "action": "log",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "AUDIT_LOG_CLEARED",
      "name": "Audit / Security Log Cleared",
      "type": "eventlog",
      "event_id": 1102,
      "action": "log",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "SYSTEM_LOG_CLEARED",
      "name": "System Log Cleared",
      "type": "eventlog",
      "event_id": 104,
      "action": "log",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "FIREWALL_DISABLED",
      "name": "Firewall Profile Disabled",
      "type": "eventlog",
      "event_id": 2003,
      "action": "log",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "AUDIT_POLICY_CHANGED",
      "name": "Audit Policy Changed",
      "type": "eventlog",
      "event_id": 4719,
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "NEW_SERVICE",
      "name": "New Service Installed",
      "type": "eventlog",
      "event_id": 7045,
      "action": "log",
      "severity": "medium",
      "enabled": true
    },
    {
      "id": "SCHTASK_CREATED",
      "name": "Scheduled Task Created",
      "type": "eventlog",
      "event_id": 4698,
      "action": "log",
      "severity": "medium",
      "enabled": true
    },
    {
      "id": "SCHTASK_DELETED",
      "name": "Scheduled Task Deleted",
      "type": "eventlog",
      "event_id": 4699,
      "action": "log",
      "severity": "medium",
      "enabled": true
    },
    {
      "id": "RDP_LOGIN",
      "name": "RDP Login Detected",
      "type": "eventlog",
      "event_id": 4624,
      "action": "log",
      "severity": "medium",
      "enabled": true
    },
    {
      "id": "SUSPICIOUS_PROCESS",
      "name": "Known Malicious Tool Detected",
      "type": "process",
      "patterns": [
        "mimikatz", "cobaltstrike", "beacon.exe",
        "nc.exe", "nc64.exe", "ncat.exe",
        "plink.exe",
        "psexec.exe", "psexec64.exe",
        "procdump.exe", "procdump64.exe",
        "lazagne.exe",
        "rubeus.exe",
        "sharphound.exe", "bloodhound.exe",
        "winpeas.exe",
        "chisel.exe",
        "socat.exe",
        "msfconsole", "msfvenom"
      ],
      "action": "kill_process",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "POWERSHELL_ENCODED",
      "name": "Encoded PowerShell Command",
      "type": "process",
      "patterns": ["-EncodedCommand", "-enc ", "-ec "],
      "action": "kill_process",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "POWERSHELL_HIDDEN",
      "name": "PowerShell Hidden Window",
      "type": "process",
      "patterns": ["-w hidden", "-WindowStyle Hidden", "-noprofile -exec bypass"],
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "CERTUTIL_DOWNLOAD",
      "name": "Certutil Used for Download (LOLBAS)",
      "type": "process",
      "patterns": ["-urlcache", "-split", "-decode"],
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "REGSVR32_SCRIPTLET",
      "name": "Regsvr32 Scriptlet Execution (LOLBAS)",
      "type": "process",
      "patterns": ["regsvr32", "/s /n /u /i:"],
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "MSHTA_EXEC",
      "name": "MSHTA Remote Execution (LOLBAS)",
      "type": "process",
      "patterns": ["mshta.exe", "mshta http", "mshta vbscript"],
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "WSCRIPT_CSCRIPT",
      "name": "Script Engine Executing Remote/Suspicious Script",
      "type": "process",
      "patterns": ["wscript.exe", "cscript.exe"],
      "action": "log",
      "severity": "medium",
      "enabled": true
    },
    {
      "id": "TEMP_EXECUTABLE",
      "name": "Executable Launched from Temp Directory",
      "type": "process",
      "patterns": ["\\Temp\\", "\\AppData\\Local\\Temp\\"],
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "REVERSE_SHELL_PORT",
      "name": "Reverse Shell Port (C2)",
      "type": "network",
      "ports": [4444, 1337, 9001, 8888, 4445, 5555, 6666, 7777, 31337],
      "direction": "outbound",
      "action": "block_ip",
      "severity": "critical",
      "enabled": true
    },
    {
      "id": "SMB_SCAN",
      "name": "Outbound SMB (Possible Lateral Movement)",
      "type": "network",
      "ports": [445, 139],
      "direction": "outbound",
      "action": "log",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "SUSPICIOUS_DOWNLOAD",
      "name": "Suspicious File Dropped in Downloads/Temp",
      "type": "file",
      "patterns": [".exe", ".scr", ".pif", ".bat", ".cmd", ".ps1", ".vbs", ".hta", ".cpl", ".dll"],
      "action": "quarantine",
      "severity": "high",
      "enabled": true
    },
    {
      "id": "RANSOMWARE_EXTENSION",
      "name": "Ransomware File Extension Pattern",
      "type": "file",
      "patterns": [".locked", ".crypt", ".encrypt", ".wnry", ".locky"],
      "action": "log",
      "severity": "critical",
      "enabled": true
    }
  ]
}
